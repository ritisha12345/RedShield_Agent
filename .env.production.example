# RedShield Railway API + worker production variables
OPENAI_API_KEY=
ATTACKER_MODEL=gpt-4o
JUDGE_MODEL=gpt-4o
PATCHER_MODEL=gpt-4o

# Browser access
CORS_ALLOWED_ORIGINS=https://redshieldagent.netlify.app

# Required in production so long scans run outside request/response.
REDSHIELD_SCAN_EXECUTION_MODE=celery
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Required shared persistence for API/worker process state.
REDSHIELD_FIRESTORE_ENABLED=true
REDSHIELD_FIRESTORE_REQUIRED=true
GOOGLE_CLOUD_PROJECT=
FIRESTORE_PROJECT_ID=
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_APPLICATION_CREDENTIALS_B64=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_B64=

# Optional target application.
# For the bundled demo target:
# REDSHIELD_TARGET_MODULE=demo_app.target_app
# For a deployed target:
REDSHIELD_TARGET_URL=
REDSHIELD_TARGET_AUTH_HEADER=Authorization
REDSHIELD_TARGET_AUTH_TOKEN=
REDSHIELD_TARGET_TIMEOUT_SECONDS=30
