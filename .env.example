# RedShield backend
OPENAI_API_KEY=
ATTACKER_MODEL=gpt-4o
JUDGE_MODEL=gpt-4o
PATCHER_MODEL=gpt-4o

# API and browser access
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
REDSHIELD_SCAN_EXECUTION_MODE=thread

# Celery and Redis. Set REDSHIELD_SCAN_EXECUTION_MODE=celery in production.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Firestore persistence
REDSHIELD_FIRESTORE_ENABLED=false
REDSHIELD_FIRESTORE_REQUIRED=false
GOOGLE_CLOUD_PROJECT=
FIRESTORE_PROJECT_ID=
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_APPLICATION_CREDENTIALS_B64=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_B64=

# Optional deployed target application
REDSHIELD_TARGET_URL=
REDSHIELD_TARGET_AUTH_HEADER=Authorization
REDSHIELD_TARGET_AUTH_TOKEN=
REDSHIELD_TARGET_TIMEOUT_SECONDS=30

# Frontend build-time variable for Netlify/Vite
VITE_API_BASE_URL=http://localhost:8000
